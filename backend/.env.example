SECRET_KEY="django-insecure-replace-me-in-production"
DEBUG=True
ALLOWED_HOSTS="localhost,127.0.0.1"
CORS_ALLOWED_ORIGINS="http://localhost:5173"

# Open Library Contact (Required for API headers)
OPEN_LIBRARY_CONTACT="your-email@example.com"

# Gemini API Key (Required for AI triage recommendations)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# eBay Browse API (Optional — enables real market pricing in recommendations)
# Register at: https://developer.ebay.com → create an app → copy Production keys
# Without these, valuation_data will always be empty and the AI uses intuition only
EBAY_CLIENT_ID="your-ebay-client-id"
EBAY_CLIENT_SECRET="your-ebay-client-secret"

# Demo Mode (Optional — mock eBay market data when API credentials are not yet configured)
# Set to any non-empty value to activate. Mock prices are deterministic per ISBN but not real.
# Remove or leave blank in production.
# DEMO_MODE=True

# Request timeout in seconds for external API calls (Open Library, eBay)
# REQUESTS_TIMEOUT=10
